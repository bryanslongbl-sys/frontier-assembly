# ============================================================================
# Frontier Assembly — environment
# Copy to `.env` and fill in. The default lineup needs ONLY NEBIUS_API_KEY.
# ============================================================================

# --- Nebius Token Factory (inference) --- REQUIRED ---------------------------
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/

# --- Lineup ------------------------------------------------------------------
# 0 = all-Nebius default (one key, fully reproducible).
# 1 = cross-frontier debate (Claude Architect, GPT Critic, Nebius Synthesizer).
USE_CROSS_VENDOR=0

# Override any role's model in ONE line (optional):
# ARCHITECT_MODEL=meta-llama/Llama-3.3-70B-Instruct
# CRITIC_MODEL=Qwen/Qwen2.5-72B-Instruct
# SYNTH_MODEL=meta-llama/Llama-3.3-70B-Instruct

# --- Cross-vendor keys (only needed when USE_CROSS_VENDOR=1) ------------------
# Sanctions-clean: Western providers + native Nebius only.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
GEMINI_API_KEY=
LLAMA_API_KEY=

# --- Debate sizing -----------------------------------------------------------
MAX_ROUNDS=2
MAX_TOKENS=1500
MODEL_TIMEOUT=60

# --- Nebius Object Storage (Serverless Job / endpoint only) ------------------
# Not needed for `python -m scripts.run_local` (that uses ./artifacts).
NEBIUS_S3_ENDPOINT=https://storage.eu-north1.nebius.cloud:443
S3_BUCKET=frontier-assembly
AWS_REGION=eu-north1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
